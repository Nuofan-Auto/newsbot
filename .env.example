# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Providers — fill in one to enable real analysis; leave blank to use Mock mode
# Priority: GLM → MiniMax → Claude → Mock
GLM_API_KEY=
CLAUDE_API_KEY=
MINIMAX_API_KEY=

# Cache retention: articles older than this many days are purged on each /news run (default: 7)
CACHE_MAX_DAYS=7

# Web Search (Serper.dev — needed for /search and /explore)
# Sign up free at https://serper.dev (2,500 free queries/month, no credit card required)
SERPER_API_KEY=
